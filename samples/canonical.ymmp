e":"メモ帳","SavedState":"{\"FilePath\":\"\",\"Text\":\"\",\"Zoom\":1.0,\"IsSaved\":true}"},"YukkuriMovieMaker.Plugin.Community.Tool.Notepad.NotepadViewModel/8b916d15-dfb1-4a2c-b844-3d2e3a92c96d":{"Title":"メモ帳","SavedState":"{\"FilePath\":\"\",\"Text\":\"\",\"Zoom\":1.0,\"IsSaved\":true}"},"YukkuriMovieMaker.Plugin.Community.Tool.Notepad.NotepadViewModel/9afa903a-8ece-41fd-9f6f-f217cc676e55":{"Title":"メモ帳","SavedState":"{\"FilePath\":\"\",\"Text\":\"\",\"Zoom\":1.0,\"IsSaved\":true}"},"YukkuriMovieMaker.ViewModels.VolumeAnalyzerViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.SearchViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.ResourceListViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.SettingsViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.ScenarioEditorViewModel":{"Title":"","SavedState":"{\"FilePath\":\"C:\\\\Users\\\\thank\\\\Storage\\\\Media Contents Projects\\\\NLMYTGen\\\\samples\\\\v14_t3_ymm4.csv\",\"IsSaved\":false,\"Lines\":[{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"あの、想像してみてください。\\nある朝目覚めると、\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ま、世界のエネルギー供給の\\n 20% が跡形もなく消滅していると。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ、いきなりですよね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"そうなんですよ。なんか\\n徐々に減っていくんじゃなくて\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"巨大なスイッチが急に切られたみたいに、\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"たった数日で起きるんです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"これちょっとした SF 映画の\\nオープニングみたいじゃないですか?\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"全くですね。でも、えっと、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"残念ながらこれはフィクションではなくって\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"現在の中東で現実に\\n起きていることなんです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"はい。今日はリスナーのあなたが\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"送ってくれたレポートとデータを\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"徹底解剖するディープダイブです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"あなたが集めてくれたこのリソース、\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"本当に素晴らしい視点に\\n溢れていましたよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"そうですね。かなり踏み\\n込んだ分析ばかりで。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ええ。で、今回の私たちのミッションは\\n単なる原油価格が\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"高騰しているみたいなそういう\\n表面的なニュースのノイズを\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"完全に排除することです。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"なるほど。本質を見極めると。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"その通りです。あなたが\\n日々チェックしている\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ポートフォリオとか日常の消費行動の裏側で\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"世界経済の\\n OS つまりオペレーティングシステムそのものが\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"今どう書き換えられようとしているのか\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"そのシステムの変化を\\n抽出していきたいと思います。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"私もあのあなたが共有してくれた\\n分析データを改めて見て正直背筋が\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"凍る思いでした。この事態は単に\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ガソリン代が上がるとかそういう\\nレベルの話ではないんですよね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ていうかもっと根本的なところですよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ。世界経済の血液の循環が物理的に\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"止まった時どの臓器が最初に悲鳴を\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"上げるのか、そしてどんな連鎖反応、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"つまりカスケード効果が起きるのか。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"今日はそのメカニズムを徹底的に\\n深掘りしていきましょう。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"是非お願いします。で、\\nまずはあなたが送ってくれた資料の最初の\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"セクションにあったあの現場で起きている\\n物理的な現実から見ていきたいんですけど\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"はい。あのショッキングな数字ですね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"そう。あの数字何度見ても目を疑いますよ。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ホルムズ海峡のタンカー通行量がわずか\\n 1 週間で、えっと 95% も\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"減少しているんですよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ、しかも原油の積み出しに至っては\\n 99% ですからね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"つまり海峡が実質的に\\n機能停止しているっていうことじゃないですか?これ\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"その通りです。パーセンテージだけだと\\n規模感は掴みにくいですよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"でも物理的インパクトで見ると、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"世界の石油供給の\\n 15% から 20% が危険にさらされています。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"さらに LNG、つまり液化天然ガス貿易の\\n 22% も危険圏です。22% ですか?\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"はい。例えるなら世界のエネルギーの\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"大動脈に巨大な血栓がっつり\\n詰まった状態と言えますね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ああ、なるほど。その結果としてブレント原油は\\n 1 ヶ月で 59% も\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"急騰して一時 116 ドルから\\n 119 ドル付近まで到達したと。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"これ 1990 年の湾岸戦争時を\\n凌駕する上昇ペースですよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"あなたが提供してくれた\\nチャートにも明確に出てましたよね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ええ、そこがすごく重要でここで\\n比較すべきなのは\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ウクライナ進行が始まった\\n 2022 年の時とのあの\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"構造的な違いなんですよ。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"構造的な違いというと\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"あの時も世界はロシア産原油の\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"供給喪失にパニックになってブレント原油は\\n 140 ドル近くまで跳ね上がりましたよね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"でも冷静にデータを\\n振り返ると当時失われたロシア産原油の\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"シェアって世界全体の\\n 7% から 8% 程度だったんです。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"あ、今回はその倍、15% から 20% が\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"市場から消えようとしているってことですよね。\\nでも現時点では 2022\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\" 年ほどの価格爆発には至っていないようにも\\n見えますけどなぜなんでしょう?\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"それはですね端的に\\n言ってバッファーの違いです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"現在 OECD 諸国の原油在庫は\\n 2022 年当時よりも、ま、 2\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\" 億バレル多く積み上がっているんですね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"2 億バレルですか?\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"はい。つまり世界は今備蓄という名の貯金を\\n必死に取り崩してなんとか食いつないでいる\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"状態なんですよ。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"でもそれっていつまでも続かないですよね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ええ、喪失供給量が圧倒的に多いですから、\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"もしこの物理的な遮断が\\n 2 週間あるいはそれ\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"以上完全に続いてしまったら、その 2\\n 億バレルのバッファーすら一瞬で\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"蒸発します。アメリカとかでもあの\\n LNG の生産能力を追加しようっていう\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"動きはありますよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ありますけど正直中東の損失規模を\\n補うには全く足りません。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"まあ例えるなら燃える山火事を水鉄砲で\\n消そうとしているようなそんな状況ですね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"うーん。それは絶望的ですね。\\nあの送ってくれた\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"マクロ経済のレポートを読みながら\\n私が感じたのはこれってまさに最悪の\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"タイミングの母というか\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ザ・マザー・オブ・タイミングズだなってことなんです。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"最悪のタイミングの母、面白い表現ですね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"コロナ禍のサプライチェーン分断とか\\n関税の後遺症からあのようやく\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"世界経済の身体が回復してインフレも\\n落ち着き始めていたじゃないですか。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"その矢先に最も重要な動脈を\\n突然切断されるわけですから。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"まさにその通りです。たださらに\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"厄介なのはその切断によるダメージがえっと\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"世界中どこでも同じように\\n現れるわけではないってことなんですよ。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"というと\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ここにすごく恐ろしい非対称性、\\n要するに不平等な痛みが存在しているんです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ああ、なるほど。アジアと欧州の\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"惨状ですね。あなたが提供してくれた\\nページ 4 のデータを見たんですけど、\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ペルシャ湾の石油に約 90% も依存している\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"日本とかフィリピンみたいな\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"アジア諸国はもう致命的な脆弱性を\\n露呈していますよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ、完全に直撃を受けています。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"一部のアジア諸国ではすでに\\n在宅勤務の義務化とか\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"燃料割り当て制っていうなんかまるで\\n戦時下みたいな緊急事態に陥ってますし\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"はい。エネルギーをほぼ完全に輸入に\\n頼っている国にとってエネルギー価格の\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"高騰は単なる物価高ではなくて\\n国富の流出を意味するんです。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"インドの通貨ルピーが対ドルで\\n 92.48 という過去最安値を\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"記録したのもその典型的な例ですね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"つまり高騰したドル建ての石油をどうしても\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"買わなきゃけないから\\n自国通貨であるルピーを\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"投げ売りしてでもドルを手に入れていると\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"そうです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"で結果として自国の通貨価値が\\n暴落してさらに輸入物価が\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"上がるっていうあの悪循環ですよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"まさにそのメカニズムです。自国通貨安が\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"インフレをさらに加速させるいわゆる\\n輸入インフレの地獄ですね。一方で、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ま、欧州も非常に深刻な状況でして、\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ええ、ECB つまりヨーロッパ中央銀行は金利を\\n 2% に据え置いていますけど\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"はい。エネルギー高でインフレが\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"再燃しているのに経済成長は\\n完全に鈍化していますから、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"いわゆるスタグフレーションの危機に\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"直面しているわけです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"厳しいですね。ここであなたが\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"共有してくれた主要な投資銀行の\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"アナリストレポートについてちょっと\\n聞かせてください。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"彼ら世界株式の評価をイコールウェイトに\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"引き下げましたよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ、引き下げましたね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"リスナーの皆さんのためにこれが\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"実際のポートフォリオにとって何を\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"意味するのか少し噛み砕いてもらえますか?\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"分かりました。イコールウェイト、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"つまり中立という評価は金融業界特有の\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"控えめな表現です。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"実質的には今は積極的に\\n株を買う理由は全くない、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"というかなり強い警戒シグナルなんです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"なるほど。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"株式市場全体の\\nリターンがもうリスクのない現金や\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"国債と同程度しか見込めないだろうと\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"彼らは分析しているわけですね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"さらに恐ろしいのがその\\n先のシナリオですよね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"もし原油が 150 ドルから\\n 180 ドルに達した場合、\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"世界の株式バリュエーションは\\n 25% も縮小すると予測されています。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ、4分の1が吹き飛ぶ計算になります。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"なんでそこまで\\n極端な破壊力があるんですか?\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"それはですね、原油が\\n 150 ドルを超えてしまうとあらゆるものの\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"製造コストと輸送コストがま限界を\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"突破してしまうからです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ああ、利益が出せなくなると。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"その通りです。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"今の世界経済には、\\n高金利という重しを背負ったままこの\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"コスト増を吸収する体力がほとんど\\n残っていません。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"企業の利益率は急減し、その結果が株価の\\n 25% 縮小として現れる、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"というメカニズムです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"なるほど。理屈は完璧に腑に落ちました。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"でもちょっとここで視点を\\n変えさせてください。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"はい。どうぞ。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"欧州やアジアが苦しんでいるのは事実です。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"でもあなたが送ってくれた\\n資金フローのデータを\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"見ると危機が起きるたびに\\n資金は安全資産として米国債や\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"現金つまりアメリカに逃避していますよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ、明確なトレンドとして出ています。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"おまけにアメリカは世界最大級の\\nシェールオイル生産国でもあるじゃないですか。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"相対的に見ればアメリカはこの危機における\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"唯一の勝者というか最強の\\n防衛的市場として機能しているんじゃないですか。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"な、まさにそこがこの問題の最も\\n深くかつ巨大なパラドックスを孕んでいる\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"部分なんですよ。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"パラドックスですか?\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"はい。確かに短期的、マクロ的に\\n見ればアメリカの防衛産業や\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"エネルギー企業は信じられない\\n規模の想定外の利益、\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"いわゆるウィンドフォール・プロフィットを\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"享受しています。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ええ、株価も上がってますよね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"そこであなたが送ってくれた\\n資料の中核にもある\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"軍事ケインズ主義という概念に\\n入っていきましょうか。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"軍事ケインズ主義。あの\\nケインズ主義って普通は不景気の\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"時に政府が橋を作ったり道路を直したりして\\n雇用を生み出すあの公共事業の話ですよね。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"それが軍事になるとどう違うんですか?\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"基本的な論理は同じなんですよ。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"政府の支出によって経済成長を\\n刺激しようというものです。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ただ対象がインフラではなくて\\n軍事支出になるんです。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"なるほど。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"この概念は古くて 1933\\n 年にあのジョン・メイナード・ケインズ自身が\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"フランクリン・ルーズベルト大統領に\\n宛てて書いた書簡で戦争が常に\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"産業活動を激化させてきたと\\n指摘したことにまで遡ります。\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"橋を作る代わりに戦闘機や\"},{\"CharacterName\":\"ゆっくり霊夢赤縁\",\"Text\":\"ミサイルを作ることで\\n GDP を押し上げるわけですね。\"},{\"CharacterName\":\"ゆっくり魔理沙黄縁\",\"Text\":\"ええ、経済の数字上は橋でも\\nミサイルでも同