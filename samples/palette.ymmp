"YukkuriMovieMaker.Plugin.Tachie.AnimationTachie.AnimationTachieManagerViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.TranscriptionViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.SettingsViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.Plugin.Community.Tool.Explorer.ExplorerViewModel/38e4b1b1-5722-4109-aedd-ae127b059eb7":{"Title":"","SavedState":"{\"Location\":\"C:\\\\\",\"Layout\":{\"Mode\":\"List\",\"IconSize\":16,\"ItemWidth\":\"NaN\",\"ItemHeight\":16.0,\"MaxTextHeight\":11.0},\"Filter\":{\"IsFiltered\":false,\"IsFilteredByExtension\":false,\"IsVideoVisible\":true,\"IsAudioVisible\":true,\"IsImageVisible\":true,\"IsTextVisible\":true,\"IsOtherVisible\":true,\"IsDirectoryVisible\":true,\"SearchText\":\"\"},\"SortKey\":\"Name\",\"SortOrder\":\"Ascending\"}"},"NLMSlidePlugin.ToolPlugin.CsvImportToolViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.Plugin.Community.Tool.Browser.BrowserViewModel/6b70c785-02b3-4c6d-87a4-7657e8913867":{"Title":"ブラウザ","SavedState":"{\"Location\":\"\",\"Zoom\":1.0}"},"YukkuriMovieMaker.Plugin.Community.Tool.Notepad.NotepadViewModel/9afa903a-8ece-41fd-9f6f-f217cc676e55":{"Title":"メモ帳","SavedState":"{\"FilePath\":\"\",\"Text\":\"\",\"Zoom\":1.0,\"IsSaved\":true}"},"YukkuriMovieMaker.ViewModels.SearchViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.ScenarioEditorViewModel":{"Title":"","SavedState":"{\"FilePath\":\"C:\\\\Users\\\\thank\\\\Storage\\\\Media Contents Projects\\\\NLMYTGen\\\\samples\\\\AI監視が追い詰める生身の労働_reflow_ymm4.csv\",\"IsSaved\":false,\"Lines\":[{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"ちょっと想像してみてください。\\nあなたは配送バンの運転席に座っています。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"猛暑の中で息苦しさを感じて、\\n喘息の発作が起きそうになったとします。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"え、かなりパニックになる状況ですよね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"はい。\\nそこで慌てて助手席のカバンに手を伸ばして吸入器を取り出そうとします。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"その瞬間、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"ダッシュボードに設置されたAIカメラがあなたをロックオンして「脇見運転」としてシステムに自動でフラグを立てるんです。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"なるほど。\\n人間の切実な事情は完全に無視されるわけですね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"そうなんです。\\nそしてあなたの評価スコアが下がり、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"最悪の場合にはシステムから自動的にペナルティを科される。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"これはディストピアSF映画のワンシーンではなく、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"完璧に計算されたアルゴリズムが生身の人間というノイズだらけの現実に衝突した時に、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"今まさに起きている日常なんです。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"私たちが普段「アルゴリズムによる最適化」と聞くと、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"効率的でクリーンな魔法を想像しがち\\nですが、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"もしその計算式に「人間の身体的限界」という変数が最初から欠落していたらどうなるか。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"今回の探求では、\\nその見えない労働システムの裏側に鋭く切り込んでいきます。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"あなたが次にスマホで注文を確定するボタンをタップした瞬間、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"その背後でどんな巨大なサイバーフィジカルシステムが、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"誰の汗とリスクを動力にして回り始めるのかを解剖していくということですね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"まさにその通りです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"今回は、\\n2025年から2026年にかけてのAmazonの内部資料やPR文書、\\n労働組合の実態調査、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"そしてカリフォルニア大学の最新データなど、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"多岐にわたる資料を突き合わせていきます。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"まずは、巨大な物流倉庫の中、\\nデジタル版「パノプティコン」の話から始めましょう。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"パノプティコンというのは、\\n監視者が姿を見せずに全収容者を監視でき、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"囚人が「常に見られているかもしれない」というプレッシャーで自らを規律し続けるシステムですね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"はい。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"現代の倉庫はハンドスキャナーやGPS、\\n車内カメラなどを使ってそれを実現しています。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"UNIグローバルユニオンの報告書によれば、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"倉庫労働者の71.4%がハンドスキャナーによって秒単位で生産性を追跡されていると答えています。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"彼らが持っているスキャナーは、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"単なるバーコードリーダーではなく実質的なストップウォッチなんです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"例えば、\\n一定時間アイテムをスキャンしないと、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"画面上で「タイム・オフ・タスク（タスク離脱時間）\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"」というタイマーがカチカチと動き始めます。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"労働者は自分の雇用が脅かされていくカウントダウンをリアルタイムで見せつけられながら働き続けるわけです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"IBS（過敏性腸症候群）という持病を持つ労働者の証言もありましたが、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"人間が管理していれば理解できる体調不良も、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"アルゴリズムにとっては単なる「エラーコード」でしかありません。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"システムは人間を、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"物理学の授業でよくある「摩擦のない真空状態」のような存在として前提にしているんですね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"その通りです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"パッケージのサイズの違いや加齢による体力の低下といった「現実空間の摩擦」を一切計算に入れていないんです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"ポーランドの調査では、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"66%がこの監視によって精神的健康に悪影響が出たと回答しており、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"メンタルへのダメージの方が大きいんですよ。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"彼らにとって私たちは人間ではなく、\\n完全に交換可能な機械の歯車なんです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"そして、\\nそうやって押し付けられたコストが倉庫空間から路上へと飛び出した時、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"さらに複雑な問題を引き起こします。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"カリフォルニア大学バークレー校の2024年の博士論文データでは、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"ドローンを飛ばしてデリバリードライバーの動きを客観的に解析しています。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"インセンティブ、\\nつまり報酬の割り増しは労働者には稼ぐチャンスに見えますが、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"実際はどうなのでしょう？\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"客観的なデータは全く別の物語を語っています。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"プラットフォーム企業はアルゴリズムを使い、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"「このカウントダウンが終わるまでにタスクをこなせば報酬が跳ね上がる」という環境だけを提示します。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"これは「間接的な労働統制」であり、\\n自発的にリスクを取らせる罠のようなものです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"データによると、\\nインセンティブが発生しているタスクでは、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"時速60km以上のスピード違反を犯す確率が1.61倍に増しています。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"しかも、\\nそこに「猛暑」という環境変数が加わるわけですよね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"はい。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"気温が1度上がるごとにスピード違反の確率が9%増加するという明確な相関が出ています。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"アルゴリズムは人間の生理的限界を考慮しません。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"むしろ、\\n誰も外に出たくない過酷な状況でこそ需要が増す\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"ため、\\n強力なインセンティブを発動させます。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"私たちの何気ない利便性の消費が、\\nプラットフォームの計算式を経由して、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"地元の交差点でのバイクの爆走という「物理的な事故リスク」に直接変換されている。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"リスクが企業ではなく、\\nドライバーや一般市民に外部化されている\\nということですね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"その責任の回避というキーワードで、\\nAmazonの最新のPR戦略を見てみましょう,。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"Amazonは「配送サービスパートナー（DSP）\\n」プログラムに19億ドルを投資し、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"顧客がアプリからドライバーに感謝を伝える「サンクマイドライバー」というプログラムを展開しています。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"アプリのボタン一つで感謝を伝えられるなんて、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"テクノロジーを使った温かいアプローチに見えますが。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"表面上はそうです。\\nしかし公式規約を読み込むと、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"システムのエラーやプログラムの中断に対してAmazon側は一切の法的責任を負わないという「防護壁」が張り巡らされています。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"「私たちは直接の雇用主ではない」という建前を崩さない\\nための高度な法務戦略ですね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"それに対し、\\n労働組合側は2025年10月の声明で、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"「こんなものは単なるPRスタント（宣伝行為）だ」と一刀両断しています。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"労働者が必要としているのはボタンではなく、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"安全基準や賃金について企業と対等に交渉する\\nための「権力」なんです。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"これは一種の「感謝のゲームフィケーション」であり、\\n消費者が免罪符を買うように、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"善意のクリックが構造的な問題を隠す\\nために利用されているとも言えます,。\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"私たちがワンクリックで完結させている経済活動の裏側で、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"高度なPR戦略と生身の労働運動が激突しているわけですね。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"今回の探求の最後に、\\n思考実験を提示して終わりたいと思います。\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"今後さらに気候変動が進行して、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"都市の暑さが人間の活動限界を恒常的に超えるようになった時、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"アルゴリズムは人間の生理的限界に合わせて自らを再プログラミングするのでしょうか？\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"それとも、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"生身の人間を完全に排除して無人ドローンやロボットへと置き換えるその日まで、\"},{\"CharacterName\":\"ゆっくりずー魔理沙\",\"Text\":\"インセンティブという名の鞭で人間を極限まで駆動し続けるのでしょうか？\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"人間を最適化しようとするシステムの行き着く先は「人間の適応」\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"か、それとも「排除」か。この答えを出すのは、\\nシステムを設計する企業だけでなく、\"},{\"CharacterName\":\"ゆっくりずー霊夢\",\"Text\":\"その利便性を日々消費し続けている私たち自身なのかもしれません。\"}]}"},"YukkuriMovieMaker.ViewModels.TemplateEditorViewModel":{"Title":"","SavedState":null},"YukkuriMovieMaker.ViewModels.CharacterEditorViewModel":{"Title":"","SavedState":null}}}